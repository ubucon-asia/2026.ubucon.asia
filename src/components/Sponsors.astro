---
import { sponsors } from "../data/sponsors";
import SponsorLogoAndModal from "../components/SponsorLogoAndModal.tsx";
---

<style>
  .sponsor-grid {

  }

</style>

<div class="p-section">
  <div class="row">
    <h2>Our Sponsors</h2>
  </div>
  {
    sponsors.map((level) => (
      <div class="p-section">
        <div class="row">
          <hr class="p-rule" />
        </div>
        <div class="row">
          <div class="col-3">
            <h3>{level.sponsorLevelName}</h3>
          </div>
          <div class="col-9">
            <div class="row sponsor-grid">
              {level.list.map((item) => (
                <div
                  class={`col-${level.sizeOnLargeScreen} col-medium-${level.sizeOnMediumScreen} col-small-${level.sizeOnSmallScreen}`}
                >
                  <SponsorLogoAndModal
                    name={item.name}
                    logoImageSrc={item.logoUrl}
                    description={item.description}
                    url={item.url}
                    level={level.sponsorLevelName}
                    partnerTag={item?.partnerTag}
                    showPopup={level.showPopup}
                    client:only="react"
                  />
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    ))}
</div>
